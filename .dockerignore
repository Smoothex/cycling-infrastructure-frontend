# Ignore files and directories generated by npm or yarn
node_modules
npm-debug.log
yarn-error.log

# Ignore build artifacts and temporary files
/dist
/tmp
/out-tsc
#/**/*.d.ts

# Block Nx and local build caches
.nx/
.cache/
dist/
node_modules/

# Ignore development-specific files
*.md

# Ignore version control files
.git

# Ignore Docker-specific files
.dockerignore
docker-compose.yml

# Ignore Grid Json files
/src/assets/maplibre
